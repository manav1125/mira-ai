# Core runtime
ENV_MODE=local
FRONTEND_URL=http://localhost:3000

# Core data + auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=optional-but-recommended-jwt-secret
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
DATABASE_POOLER_URL=

# Core cache / queues
# On Render, prefer REDIS_INTERNAL_URL or REDIS_PRIVATE_URL over a public REDIS_URL.
REDIS_INTERNAL_URL=redis://your-private-redis-host:6379
REDIS_PRIVATE_URL=
REDIS_URL=

# Core security
MCP_CREDENTIAL_ENCRYPTION_KEY=generate-a-32-byte-base64-key
KORTIX_ADMIN_API_KEY=optional-admin-api-key

# Main LLM
MAIN_LLM=anthropic
MAIN_LLM_MODEL=anthropic/claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_API_BASE=
OPENROUTER_API_KEY=
AWS_BEARER_TOKEN_BEDROCK=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Memory / retrieval
MEMORY_EMBEDDING_PROVIDER=openai
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
VOYAGE_API_KEY=

# Sandboxes / media / search
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=
REPLICATE_API_TOKEN=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
SERPER_API_KEY=

# Integrations / notifications / billing
COMPOSIO_API_KEY=
COMPOSIO_WEBHOOK_SECRET=
NOVU_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=
REVENUECAT_WEBHOOK_SECRET=

# Voice / trust & safety
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
REALITY_DEFENDER_API_KEY=

# Analytics / observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
BRAINTRUST_API_KEY=
